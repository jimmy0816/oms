# 資料庫連接字串
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# JWT 密鑰
JWT_SECRET="your_jwt_secret_key"

# 預設管理員帳號設定
DEFAULT_ADMIN_EMAIL="admin@example.com"
DEFAULT_ADMIN_PASSWORD="admin123"

# 其他環境變數
NODE_ENV="development"
PORT=3000


R2_ACCOUNT_ID="your_r2_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="your_r2_bucket_name"


PUBLIC_FRONTEND_URL="https://localhost:3000"


OIDC_CLIENT_ID="test_client"
OIDC_CLIENT_SECRET="test_secret"
OIDC_ISSUER="http://localhost:4000"

NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="your_nextauth_secret_key"

# Google Chat Integration
GOOGLE_CHAT_WEBHOOK_URL="https://chat.googleapis.com/v1/spaces/xxxxx/messages?key=xxxxx&token=xxxxx"
GOOGLE_CHAT_ENABLED="true"

# Bitbucket Integration
BITBUCKET_ENABLED="false"
BITBUCKET_BASE_URL="https://api.bitbucket.org/2.0"
BITBUCKET_WORKSPACE="your_workspace"
BITBUCKET_REPO_SLUG="your_repo_slug"
BITBUCKET_BOT_EMAIL="bitbucket-bot@oms.local"
BITBUCKET_BOT_NAME="Bitbucket Bot"
# 使用 Token 或 Basic Auth（二擇一）
BITBUCKET_TOKEN="your_bitbucket_access_token"
BITBUCKET_USERNAME="your_atlassian_email"
BITBUCKET_APP_PASSWORD="your_bitbucket_app_password_or_api_token"

# 測試部署公告 commit
